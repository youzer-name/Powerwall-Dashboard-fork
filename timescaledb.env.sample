# Environment variables for TimescaleDB (PostgreSQL)
#------------------------------------------------------------------------------#
# Used by the timescaledb container itself (when bundled) and by every service
# that connects to it -- telegraf-timescale, aggregate-cron, grafana, and
# weather411 -- whether that's this stack's own bundled container or an
# existing PostgreSQL/TimescaleDB server elsewhere. setup.sh's datastore
# prompt writes TIMESCALEDB_HOST/PORT/SSLMODE here for you; the defaults below
# are only used if you're editing this file by hand.
#
# setup.sh generates a random POSTGRES_PASSWORD the first time this file is
# created from this sample. Change it here (then recreate the containers) if
# you'd like to set your own.
#------------------------------------------------------------------------------#
POSTGRES_USER=telegraf_powerwall
POSTGRES_PASSWORD=changeme
POSTGRES_DB=powerwall

# Host/port TimescaleDB is reached at, from inside the compose network. The
# bundled container is always reachable as "timescaledb" on 5432 regardless
# of TIMESCALEDB_PORTS (that variable only affects *host*-side access) -- only
# change these if you're pointing at an existing server instead (setup.sh's
# datastore prompt does this for you). Not exposed outside the compose
# network by default; see TIMESCALEDB_PORTS in compose.env for that.
TIMESCALEDB_HOST=timescaledb
TIMESCALEDB_PORT=5432

# SSL mode used when connecting (libpq/psycopg2 sslmode values: disable,
# allow, prefer, require, verify-ca, verify-full). The bundled container
# doesn't speak TLS, so this must stay "disable" unless you're pointing at an
# existing server that requires it.
TIMESCALEDB_SSLMODE=disable

# Timezone -- kept in sync with the rest of the stack by tz.sh
TZ=America/Los_Angeles
