# Environment variables for TimescaleDB (PostgreSQL)
#------------------------------------------------------------------------------#
# Used by both the timescaledb container itself and the telegraf-timescale /
# aggregate-cron containers that connect to it internally (via the "timescaledb"
# Docker Compose service name -- never exposed outside the compose network by
# default, see TIMESCALEDB_PORTS in compose.env if you need external access).
#
# setup.sh generates a random POSTGRES_PASSWORD the first time this file is
# created from this sample. Change it here (then recreate the containers) if
# you'd like to set your own.
#------------------------------------------------------------------------------#
POSTGRES_USER=telegraf_powerwall
POSTGRES_PASSWORD=changeme
POSTGRES_DB=powerwall

# Timezone -- kept in sync with the rest of the stack by tz.sh
TZ=America/Los_Angeles
