[Weather411]
DEBUG = no

[API]
# Port to listen on for requests (default 8676)
ENABLE = yes
PORT = 8676

[OpenWeatherMap]
# Register and get APIKEY from OpenWeatherMap.org
APIKEY = aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# Enter your location in latitude and longitude 
LAT = xxx.xxxx
LON = yyy.yyyy
WAIT = 10
TIMEOUT = 10
# standard, metric or imperial 
UNITS = metric

[InfluxDB]
# Record data in InfluxDB server 
ENABLE = yes
HOST = influxdb
PORT = 8086
DB = powerwall
FIELD = weather
# Auth - Leave blank if not used
USERNAME =
PASSWORD =
# Influx 2.x - Leave blank if not used
TOKEN =
ORG =
URL =

[TimescaleDB]
# Record data directly in TimescaleDB (PostgreSQL) server -- bypasses
# Telegraf polling, writes straight to pw_weather_log
# HOST/PORT/DB/USER/PASSWORD/SSLMODE are kept in sync with timescaledb.env by
# setup.sh -- edit there, not here, if you're using this file directly (see
# timescaledb/README.md for the bundled-vs-external-server setup).
ENABLE = no
HOST = timescaledb
PORT = 5432
DB = powerwall
USER = telegraf_powerwall
PASSWORD =
SSLMODE = disable

